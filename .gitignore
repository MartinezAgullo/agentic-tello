# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/

# Runtime output — track the folder structure (.gitkeep) but not the captured media.
# (3D photogrammetry storage lives under snapshots/storage_3D/)
snapshots/**
!snapshots/**/
!snapshots/**/.gitkeep

# Model weights — downloaded automatically on first run (ultralytics)
*.pt
*.pth
*.onnx
*.engine

# Environment / secrets
.env
.env.*

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/

